---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
import { services } from '../data/services';
---

<BaseLayout title="Contact" description="Contactez Eclaire Plus pour un devis gratuit ou une intervention d'urgence à Abidjan.">
  <!-- Banner -->
  <section class="relative py-24 text-white overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/img/banner-bg.jpg')"></div>
    <div class="absolute inset-0 bg-brand-navy/85"></div>
    <div class="relative max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-heading text-4xl md:text-5xl font-black mb-4">Contact</h1>
      <nav class="text-gray-300"><a href="/" class="hover:text-brand-red">Accueil</a> / <span class="text-brand-red">Contact</span></nav>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-8">
      <!-- Infos -->
      <aside class="space-y-4">
        <div class="bg-brand-navy text-white p-8 rounded-xl">
          <h2 class="font-heading text-2xl font-bold mb-2">Parlons de votre projet</h2>
          <p class="text-gray-300 text-sm">Notre équipe vous répond sous 24h ouvrées.</p>
        </div>

        <div class="bg-gray-50 p-6 rounded-xl flex items-start gap-4">
          <div class="w-12 h-12 bg-brand-red/10 text-brand-red rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
          </div>
          <div>
            <h3 class="font-heading font-bold mb-1">Adresse</h3>
            <p class="text-gray-600">{site.address}</p>
          </div>
        </div>

        <div class="bg-gray-50 p-6 rounded-xl flex items-start gap-4">
          <div class="w-12 h-12 bg-brand-red/10 text-brand-red rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
          </div>
          <div>
            <h3 class="font-heading font-bold mb-1">Téléphone</h3>
            {site.phones.map((p) => (
              <a href={`tel:${p.replace(/\s/g, '')}`} class="block text-gray-600 hover:text-brand-red transition">{p}</a>
            ))}
          </div>
        </div>

        <div class="bg-gray-50 p-6 rounded-xl flex items-start gap-4">
          <div class="w-12 h-12 bg-brand-red/10 text-brand-red rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
          </div>
          <div>
            <h3 class="font-heading font-bold mb-1">Email</h3>
            <a href={`mailto:${site.email}`} class="text-gray-600 hover:text-brand-red transition">{site.email}</a>
          </div>
        </div>

        <div class="bg-gray-50 p-6 rounded-xl">
          <h3 class="font-heading font-bold mb-3">Horaires</h3>
          <ul class="space-y-1 text-sm">
            {site.hours.map((h) => (
              <li class="flex justify-between text-gray-600">
                <span>{h.day}</span>
                <span class="font-medium">{h.value}</span>
              </li>
            ))}
          </ul>
        </div>
      </aside>

      <!-- Formulaire -->
      <div class="lg:col-span-2 bg-gray-50 p-8 rounded-xl">
        <h2 class="font-heading text-2xl font-bold mb-2">Demander un devis</h2>
        <p class="text-gray-600 mb-6">Décrivez votre projet, nous reviendrons vers vous très vite.</p>

        <form id="contact-form" class="grid grid-cols-1 md:grid-cols-2 gap-5" novalidate>
          <div>
            <label class="block text-sm font-medium mb-2">Nom complet *</label>
            <input required name="name" type="text" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-brand-red focus:border-brand-red outline-none transition" placeholder="Votre nom" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-2">Téléphone *</label>
            <input required name="phone" type="tel" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-brand-red focus:border-brand-red outline-none transition" placeholder="+225 ..." />
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium mb-2">Email *</label>
            <input required name="email" type="email" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-brand-red focus:border-brand-red outline-none transition" placeholder="vous@exemple.com" />
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium mb-2">Service souhaité</label>
            <select name="service" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-brand-red focus:border-brand-red outline-none transition bg-white">
              <option value="">— Choisir —</option>
              {services.map((s) => <option value={s.title}>{s.title}</option>)}
              <option value="Autre">Autre / plusieurs</option>
            </select>
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium mb-2">Votre message *</label>
            <textarea required name="message" rows="5" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-brand-red focus:border-brand-red outline-none transition" placeholder="Décrivez votre projet..."></textarea>
          </div>
          <!-- Honeypot anti-bot : invisible aux humains, rempli par bots → on jette -->
          <div class="hidden" aria-hidden="true">
            <label>Ne pas remplir<input name="website" type="text" tabindex="-1" autocomplete="off" /></label>
          </div>
          <div class="md:col-span-2 flex flex-col gap-3">
            <button id="submit-btn" type="submit" class="bg-brand-red text-white px-8 py-3 rounded-md font-medium hover:bg-brand-red-dark transition w-full md:w-auto disabled:opacity-60 disabled:cursor-not-allowed">
              <span data-state="idle">Envoyer ma demande</span>
              <span data-state="loading" class="hidden">Envoi en cours…</span>
            </button>
            <div id="form-result" class="hidden p-4 rounded-md text-sm" role="status" aria-live="polite"></div>
            <p class="text-xs text-gray-500">
              Vos données sont transmises uniquement à Eclaire Plus et utilisées pour répondre à votre demande.
            </p>
          </div>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const result = document.getElementById('form-result') as HTMLDivElement | null;
  const idleLabel = btn?.querySelector('[data-state="idle"]') as HTMLElement | null;
  const loadingLabel = btn?.querySelector('[data-state="loading"]') as HTMLElement | null;

  const showResult = (ok: boolean, message: string) => {
    if (!result) return;
    result.textContent = message;
    result.className = ok
      ? 'p-4 rounded-md text-sm bg-green-50 text-green-800 border border-green-200'
      : 'p-4 rounded-md text-sm bg-red-50 text-red-800 border border-red-200';
  };

  const setLoading = (loading: boolean) => {
    if (!btn) return;
    btn.disabled = loading;
    idleLabel?.classList.toggle('hidden', loading);
    loadingLabel?.classList.toggle('hidden', !loading);
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    const fd = new FormData(form);
    const payload = Object.fromEntries(fd.entries());

    setLoading(true);
    showResult(true, ''); // reset
    result?.classList.add('hidden');

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json().catch(() => ({ ok: false, message: 'Réponse serveur invalide.' }));
      result?.classList.remove('hidden');
      if (res.ok && data.ok) {
        showResult(true, data.message || 'Votre demande a bien été envoyée.');
        form.reset();
      } else {
        showResult(false, data.message || `Erreur (HTTP ${res.status}).`);
      }
    } catch (err) {
      result?.classList.remove('hidden');
      showResult(false, 'Impossible de joindre le serveur. Vérifiez votre connexion.');
    } finally {
      setLoading(false);
    }
  });
</script>
