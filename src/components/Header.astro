---
import { site, nav } from '../data/site';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<header class="sticky top-0 z-50 bg-white shadow-sm">
  <!-- Top bar -->
  <div class="bg-brand-navy text-white text-sm">
    <div class="max-w-7xl mx-auto px-4 py-2 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
      <div class="flex flex-wrap items-center gap-x-6 gap-y-1">
        <a href={`tel:${site.phones[0].replace(/\s/g, '')}`} class="flex items-center gap-2 hover:text-brand-red transition">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
          {site.phones[0]}
        </a>
        <a href={`mailto:${site.email}`} class="flex items-center gap-2 hover:text-brand-red transition">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
          {site.email}
        </a>
      </div>
      <div class="flex items-center gap-3">
        <a href={site.social.instagram} aria-label="Instagram" class="hover:text-brand-red transition"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.336 3.608 1.311.975.975 1.249 2.242 1.311 3.608.058 1.266.069 1.646.069 4.85s-.011 3.584-.069 4.85c-.062 1.366-.336 2.633-1.311 3.608-.975.975-2.242 1.249-3.608 1.311-1.266.058-1.646.069-4.85.069s-3.584-.011-4.85-.069c-1.366-.062-2.633-.336-3.608-1.311-.975-.975-1.249-2.242-1.311-3.608C2.175 15.747 2.163 15.367 2.163 12s.012-3.584.07-4.85c.062-1.366.336-2.633 1.311-3.608.975-.975 2.242-1.249 3.608-1.311C8.416 2.175 8.796 2.163 12 2.163zm0 1.838c-3.142 0-3.504.012-4.736.068-1.022.047-1.578.218-1.948.362-.49.19-.84.418-1.207.785-.367.367-.595.717-.785 1.207-.144.37-.315.926-.362 1.948C3.013 8.496 3 8.858 3 12s.013 3.504.069 4.736c.047 1.022.218 1.578.362 1.948.19.49.418.84.785 1.207.367.367.717.595 1.207.785.37.144.926.315 1.948.362 1.232.056 1.594.069 4.736.069s3.504-.013 4.736-.069c1.022-.047 1.578-.218 1.948-.362.49-.19.84-.418 1.207-.785.367-.367.595-.717.785-1.207.144-.37.315-.926.362-1.948.056-1.232.069-1.594.069-4.736s-.013-3.504-.069-4.736c-.047-1.022-.218-1.578-.362-1.948-.19-.49-.418-.84-.785-1.207-.367-.367-.717-.595-1.207-.785-.37-.144-.926-.315-1.948-.362C15.504 4.013 15.142 4 12 4zm0 3.838a4.162 4.162 0 110 8.324 4.162 4.162 0 010-8.324zm0 1.838a2.324 2.324 0 100 4.648 2.324 2.324 0 000-4.648zm5.302-2.034a.972.972 0 110 1.944.972.972 0 010-1.944z"/></svg></a>
        <a href={site.social.facebook} aria-label="Facebook" class="hover:text-brand-red transition"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M22.675 0H1.325C.593 0 0 .593 0 1.326v21.348C0 23.408.593 24 1.325 24H12.82V14.708H9.692V11.08h3.128V8.413c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.464.099 2.795.143v3.241l-1.918.001c-1.504 0-1.796.715-1.796 1.763v2.31h3.587l-.467 3.629h-3.12V24h6.116c.732 0 1.325-.592 1.325-1.326V1.326C24 .593 23.407 0 22.675 0z"/></svg></a>
        <a href={site.social.linkedin} aria-label="LinkedIn" class="hover:text-brand-red transition"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a>
      </div>
    </div>
  </div>

  <!-- Main nav -->
  <div class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center" aria-label={site.name}>
      <img src="/img/logonotext.png" alt={site.name} class="h-10 w-auto" />
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'font-medium transition hover:text-brand-red',
            isActive(item.href) ? 'text-brand-red' : 'text-brand-navy',
          ]}
        >
          {item.label}
        </a>
      ))}
      <a
        href="/contact"
        class="bg-brand-red text-white px-5 py-2 rounded-md font-medium hover:bg-brand-red-dark transition"
      >
        Devis gratuit
      </a>
    </nav>

    <button
      id="mobile-menu-toggle"
      class="md:hidden p-2 text-brand-navy"
      aria-label="Menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <nav id="mobile-menu" class="md:hidden hidden border-t border-gray-200 px-4 py-3 space-y-2">
    {nav.map((item) => (
      <a
        href={item.href}
        class:list={[
          'block py-2 font-medium',
          isActive(item.href) ? 'text-brand-red' : 'text-brand-navy',
        ]}
      >
        {item.label}
      </a>
    ))}
    <a href="/contact" class="block bg-brand-red text-white text-center px-5 py-2 rounded-md font-medium">
      Devis gratuit
    </a>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
