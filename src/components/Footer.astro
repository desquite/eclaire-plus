---
import { site } from '../data/site';
import { services } from '../data/services';
---

<footer class="bg-brand-navy text-white pt-16 pb-6">
  <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
    <!-- Brand -->
    <div>
      <div class="mb-4 bg-white inline-block p-2 rounded">
        <img src="/img/logonotext.png" alt={site.name} class="h-10 w-auto" />
      </div>
      <p class="text-gray-300 mb-4">{site.tagline}.</p>
      <p class="text-gray-300 text-sm">Transformons vos idées en réalité avec des solutions de qualité.</p>
      <div class="flex gap-3 mt-4">
        <a href={site.social.facebook} aria-label="Facebook" class="w-9 h-9 rounded-full border border-brand-red flex items-center justify-center text-brand-red hover:bg-brand-red hover:text-white transition">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M22.675 0H1.325C.593 0 0 .593 0 1.326v21.348C0 23.408.593 24 1.325 24H12.82V14.708H9.692V11.08h3.128V8.413c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.464.099 2.795.143v3.241l-1.918.001c-1.504 0-1.796.715-1.796 1.763v2.31h3.587l-.467 3.629h-3.12V24h6.116c.732 0 1.325-.592 1.325-1.326V1.326C24 .593 23.407 0 22.675 0z"/></svg>
        </a>
        <a href={site.social.instagram} aria-label="Instagram" class="w-9 h-9 rounded-full border border-brand-red flex items-center justify-center text-brand-red hover:bg-brand-red hover:text-white transition">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.336 3.608 1.311.975.975 1.249 2.242 1.311 3.608.058 1.266.069 1.646.069 4.85s-.011 3.584-.069 4.85c-.062 1.366-.336 2.633-1.311 3.608-.975.975-2.242 1.249-3.608 1.311-1.266.058-1.646.069-4.85.069s-3.584-.011-4.85-.069c-1.366-.062-2.633-.336-3.608-1.311-.975-.975-1.249-2.242-1.311-3.608C2.175 15.747 2.163 15.367 2.163 12s.012-3.584.07-4.85c.062-1.366.336-2.633 1.311-3.608.975-.975 2.242-1.249 3.608-1.311C8.416 2.175 8.796 2.163 12 2.163zm0 1.838c-3.142 0-3.504.012-4.736.068-1.022.047-1.578.218-1.948.362-.49.19-.84.418-1.207.785-.367.367-.595.717-.785 1.207-.144.37-.315.926-.362 1.948C3.013 8.496 3 8.858 3 12s.013 3.504.069 4.736c.047 1.022.218 1.578.362 1.948.19.49.418.84.785 1.207.367.367.717.595 1.207.785.37.144.926.315 1.948.362 1.232.056 1.594.069 4.736.069s3.504-.013 4.736-.069c1.022-.047 1.578-.218 1.948-.362.49-.19.84-.418 1.207-.785.367-.367.595-.717.785-1.207.144-.37.315-.926.362-1.948.056-1.232.069-1.594.069-4.736s-.013-3.504-.069-4.736c-.047-1.022-.218-1.578-.362-1.948-.19-.49-.418-.84-.785-1.207-.367-.367-.717-.595-1.207-.785-.37-.144-.926-.315-1.948-.362C15.504 4.013 15.142 4 12 4zm0 3.838a4.162 4.162 0 110 8.324 4.162 4.162 0 010-8.324zm0 1.838a2.324 2.324 0 100 4.648 2.324 2.324 0 000-4.648zm5.302-2.034a.972.972 0 110 1.944.972.972 0 010-1.944z"/></svg>
        </a>
        <a href={site.social.linkedin} aria-label="LinkedIn" class="w-9 h-9 rounded-full border border-brand-red flex items-center justify-center text-brand-red hover:bg-brand-red hover:text-white transition">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
    </div>

    <!-- Services -->
    <div>
      <h3 class="font-heading font-bold text-lg mb-4">Nos Services</h3>
      <ul class="space-y-2">
        {services.map((s) => (
          <li>
            <a href={`/services/${s.slug}`} class="text-gray-300 hover:text-brand-red transition">{s.title}</a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <h3 class="font-heading font-bold text-lg mb-4">Nous Contacter</h3>
      <ul class="space-y-3 text-gray-300">
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-brand-red flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
          <span>{site.address.full}</span>
        </li>
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-brand-red flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
          <a href={`mailto:${site.email}`} class="hover:text-brand-red transition">{site.email}</a>
        </li>
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-brand-red flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
          <div class="flex flex-col">
            {site.phones.map((p) => (
              <a href={`tel:${p.replace(/\s/g, '')}`} class="hover:text-brand-red transition">{p}</a>
            ))}
          </div>
        </li>
      </ul>
    </div>

    <!-- Hours -->
    <div>
      <h3 class="font-heading font-bold text-lg mb-4">Heures d'ouverture</h3>
      <p class="text-gray-300 mb-3">Nous soutenons nos clients 24h/24</p>
      <ul class="space-y-2">
        {site.hours.map((h) => (
          <li class="flex justify-between text-gray-300">
            <span>{h.day}</span>
            <span class="font-medium">{h.value}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Bottom -->
  <div class="max-w-7xl mx-auto px-4 mt-12 pt-6 border-t border-white/10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 text-gray-400 text-sm">
    <p>© {new Date().getFullYear()} {site.name}. Tous droits réservés.</p>
    <div class="flex gap-6">
      <a href="/mentions-legales" class="hover:text-brand-red transition">Mentions légales</a>
      <a href="/politique-confidentialite" class="hover:text-brand-red transition">Politique de confidentialité</a>
    </div>
  </div>
</footer>
